## DERMA AI — Environment Variables
## Copy this file to .env and fill in your credentials
## Never commit the real .env to version control

# ── Supabase (optional — app works in demo mode without these) ──
VITE_SUPABASE_URL=YOUR_SUPABASE_URL
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ── HuggingFace FastAPI Backend (optional — app uses mock AI without this) ──
# Deploy your FastAPI on HuggingFace Spaces and paste the URL here
VITE_HF_API_URL=https://YOUR_USERNAME-derma-ai-api.hf.space

# ── App info ──
VITE_APP_NAME=DERMA AI
VITE_APP_VERSION=1.0.0
